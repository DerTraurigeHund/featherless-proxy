# Featherless Proxy Configuration

# Featherless API
FEATHERLESS_API_BASE=https://api.featherless.ai/v1
FEATHERLESS_API_KEY=your-featherless-api-key-here

# Total concurrent connections available on your plan
MAX_CONCURRENT_CONNECTIONS=16

# Cache TTL in seconds
CACHE_TTL=60

# Queue promotion: a waiting request is raised by one priority level for each
# full window of this length it spends in the queue (default 120 seconds).
PROMOTE_AFTER_SECONDS=120

# Server
HOST=0.0.0.0
PORT=8080

# Database
DATABASE_PATH=proxy.db